{
  "name": "pivoo-backend",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
